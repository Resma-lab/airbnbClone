<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <h1 class="col-6 offset-3 font-weight-normal">Login on wanderlust</h1>
    <div class="col-6 offset-3">
        <form action="/login" method="POST" class="form-signup needs-validation" novalidate>
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input 
                  name="username"
                  id="username"
                  type="text" 
                  class="form-control"   
                  required 
                />
                <div class="valid-feedback">Nice username!!</div>
                <div class="invalid-feedback">Please enter a username.</div>
            </div>
        
            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input 
                  name="password"
                  id="password"
                  type="password" 
                  class="form-control"   
                  required 
                />
                <div class="invalid-feedback">Please enter a password.</div>
            </div>
            <div class="d-flex justify-content-center">
                <button type="submit" class="btn btn-success login">Login</button>
            </div>
            
            <div class="d-flex justify-content-center mt-3">
                <a href="/signup" class="caA">Create an Account</a>
            </div>

            <div class="d-flex justify-content-center gap-3 mt-4 social-icons">
              <a href="/auth/google" class="btn social-btn google">
                <i class="fab fa-google"></i>
              </a>
              <a href="/auth/facebook" class="btn social-btn facebook">
                <i class="fab fa-facebook-f"></i>
              </a>
              <a href="/auth/instagram" class="btn social-btn instagram">
                <i class="fab fa-instagram"></i>
              </a>
      </div>
        </form>
    </div>
</div>
 
<style>
.caA {
  color: #9607bd;
  font-weight: 500;
  display: inline-block;
}
.caA:hover{
  color: #510565;
}

.social-icons .social-btn {
  width: 50px;
  height: 50px;
  font-size: 20px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
}

.social-btn.google {
  background-color: #db4437;
}

.social-btn.facebook {
  background-color: #3b5998;
}

.social-btn.instagram {
  background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fd5949 45%, #d6249f 60%, #285AEB 90%);
}

.social-btn:hover {
  opacity: 0.85;
  text-decoration: none;
}
</style>

