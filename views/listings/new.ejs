<% layout("/layouts/boilerplate") %>
    
<div class="row">
    <div class="col-8 offset-2">
        <br><br>
        <h3>Create a New Listing</h3>
        <form 
          method="POST" 
          action="/listings"  
          novalidate class="needs-validation" 
          enctype="multipart/form-data"
        >
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input 
              name="listing[title]" 
              placeholder="Add a catchy title" 
              type="text" 
              class="form-control"
              required
            />
            <div class="valid-feedback">Wow! Title looks good.</div>
            <div class="invalid-feedback">Please add a title!</div>
        </div>

        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea 
              name="listing[description]" 
              placeholder="Enter Description" 
              type="text" 
              class="form-control"
              required
            ></textarea>
            <div class="valid-feedback">Great job! Your descripition has been saved successfully.</div>
            <div class="invalid-feedback">Please add a description!</div>
        </div>

        <div class="mb-3">
            <label for="images" class="form-label">Upload Listing Image</label>
            <input 
              name="listing[images]"  
              type="file" 
              class="form-control"
              multiple
              id="imageUpload"
              required
            />
        </div>

        <div id="imagePreview" class="row mt-3 d-flex flex-wrap gap-3"></div>


        <div class="row">
            <div class="mb-3 col-md-4">
                <label for="price" class="form-label">Price</label>
                <input 
                  name="listing[price]"
                  placeholder="Enter Price" 
                  type="number"
                  class="form-control" 
                  required     
                />
                <div class="valid-feedback">Awesome! Price has saved successfully.</div>
                <div class="invalid-feedback">Please add a valid price!</div>
            </div>
    
            <div class="mb-3 col-md-8">
                <label for="country" class="form-label">Country</label>
                <input 
                  name="listing[country]"
                  placeholder="Enter Country" 
                  type="text"
                  class="form-control" 
                  required
                />
                <div class="valid-feedback">Your country is added successfully.</div>
                <div class="invalid-feedback">Please add a valid country name!</div>
            </div>
        </div>

        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input 
              name="listing[location]"
              placeholder="Enter Location" 
              type="text"
              class="form-control" 
              required
            />
            <div class="valid-feedback">Your location is added successfully.</div>
            <div class="invalid-feedback">Please add a valid location name!</div>
        </div>
        
        <button class="btn btn-dark add-btn mt-3">Add</button>
        <br><br><br><br>
    </form>
    </div>
</div>

<script>
  const imageUpload = document.getElementById("imageUpload");
  const imagePreview = document.getElementById("imagePreview");

  // 🧠 Store all selected files here
  let selectedFiles = [];

  imageUpload.addEventListener("change", function (event) {
    const newFiles = Array.from(event.target.files);

    // Add new files to existing ones
    selectedFiles.push(...newFiles);

    // 🧹 Clear previous previews
    imagePreview.innerHTML = "";

    // 🛠️ Rebuild FileList for input
    const dataTransfer = new DataTransfer();
    selectedFiles.forEach((file) => dataTransfer.items.add(file));
    imageUpload.files = dataTransfer.files;

    // 🖼️ Show all selected previews
    selectedFiles.forEach(file => {
      const reader = new FileReader();
      reader.onload = function (e) {
        const img = document.createElement("img");
        img.src = e.target.result;
        img.classList.add("img-thumbnail", "m-2");
        img.style.maxWidth = "150px";
        img.style.maxHeight = "150px";
        imagePreview.appendChild(img);
      };
      reader.readAsDataURL(file);
    });
  });
</script>


