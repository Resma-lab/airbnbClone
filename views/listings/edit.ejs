<% layout("/layouts/boilerplate") %>

<style>
  .show-images-edit{
    display: flex;
    color: rgb(255, 0, 102);
    text-decoration: none;
    border-radius: 3px;
    height: 1.7rem;
    margin-top: 4.5rem;
    justify-items: center;
    align-items: center;
    margin-right: 17px;
    padding: 5px;
    animation: blinkColors 1s infinite;
    p{
        margin-top: 13px;
        font-size: 1rem;
    }
  }
  @keyframes blinkColors {
    0%   { color: red; }
    20%   { color: blue; }
    40%   { color: red; }
    60%   { color: blue; }
    80%   { color: red; }
    100%  { color: blue; }
  }
</style>

<div class="row">
    <div class="col-8 offset-2">
        <br> <br>
        <h3>Edit the listing</h3>
        <form 
          method="POST" 
          action="/listings/<%= listing._id %>?_method=PUT"
          novalidate
          class="needs-validation"
          enctype="multipart/form-data"
        >
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input 
                  name="listing[title]" 
                  value="<%= listing.title %>"
                  type="text" 
                  class="form-control"
                  required
                />
                <div class="valid-feedback">Great job! Title has been updated successfully.</div>
                <div class="invalid-feedback">Please add a title!</div>
            </div>
    
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea 
                  name="listing[description]" 
                  type="text" 
                  class="form-control"
                  required
                > <%= listing.description %>
                </textarea>
                <div class="valid-feedback">Awesome! descripition has been updated successfully.</div>
                <div class="invalid-feedback">Please add a descripition!</div>
            </div>

            <div class="mb-3">
              Original Listing Image <br/>
              <div class="d-flex">
                <% selectedImages.forEach((img) => { %>
                  <img src="<%= img.url %>" width="200" height="100" class="me-2" />
                <% }); %>
                <a href="/listings/<%= listing._id%>/Showimages" class="d-flex show-images-edit">
                  <p>Manage all images</p>
                </a>
              </div>
            </div>

            <div class="mb-3">
                <label for="images" class="form-label">Upload New Image</label>
                <input 
                  name="listing[images]" 
                  type="file" 
                  class="form-control"
                  multiple
                  id="imageUpload"
                />
                <div class="valid-feedback">Great job! Your image has been updated successfully.</div>
                <div class="invalid-feedback">Please add a valid image url link!</div>
            </div>
            <div id="imagePreview" class="row mt-3 d-flex flex-wrap gap-3"></div>
    
            <div class="row">
                <div class="mb-3 col-md-4">
                    <label for="price" class="form-label">Price</label>
                    <input 
                      name="listing[price]"
                      value="<%= listing.price %>" 
                      type="number"
                      class="form-control" 
                      required
                    />
                    <div class="valid-feedback">Awesome! Price has been updated successfully.</div>
                    <div class="invalid-feedback">Please add a valid price!</div>
                </div>
        
                <div class="mb-3 col-md-8">
                    <label for="country" class="form-label">Country</label>
                    <input 
                      name="listing[country]"
                      value="<%= listing.country %>"
                      type="text"
                      class="form-control" 
                      required
                    />
                    <div class="valid-feedback">Awesome! Your country has been updated successfully.</div>
                    <div class="invalid-feedback">Please add a valid country name!</div>
                </div>
            </div>
    
            <div class="mb-3">
                <label for="location" class="form-label">Location</label>
                <input 
                  name="listing[location]"
                  value="<%= listing.location %>" 
                  type="text"
                  class="form-control" 
                  required
                />
                <div class="valid-feedback">Awesome! Your location has been updated successfully.</div>
                <div class="invalid-feedback">Please add a valid location name!</div>
            </div>
    
            <button class="btn edit-btn btn-dark mt-3">Save Changes</button>
            <br> <br> <br> <br>
        </form>
    </div>
</div>
<script src="/js/script.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

<script>
  const imageUpload = document.getElementById("imageUpload");
  const imagePreview = document.getElementById("imagePreview");

  // 🧠 Store all selected files here
  let selectedFiles = [];

  imageUpload.addEventListener("change", function (event) {
    const newFiles = Array.from(event.target.files);

    // Add new files to existing ones
    selectedFiles.push(...newFiles);

    // 🧹 Clear previous previews
    imagePreview.innerHTML = "";

    // 🛠️ Rebuild FileList for input
    const dataTransfer = new DataTransfer();
    selectedFiles.forEach((file) => dataTransfer.items.add(file));
    imageUpload.files = dataTransfer.files;

    // 🖼️ Show all selected previews
    selectedFiles.forEach(file => {
      const reader = new FileReader();
      reader.onload = function (e) {
        const img = document.createElement("img");
        img.src = e.target.result;
        img.classList.add("img-thumbnail", "m-2");
        img.style.maxWidth = "150px";
        img.style.maxHeight = "150px";
        imagePreview.appendChild(img);
      };
      reader.readAsDataURL(file);
    });
  });
</script>
