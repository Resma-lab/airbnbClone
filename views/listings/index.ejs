    <div class="row row-cols-lg-4 row-cols-md-2 row-cols-sm-1">
      <% for(let listing of allListings) { %>
        <div class="listing-card position-relative mb-4">
          
          <!-- add to wishlist button  -->
          <div class="wishlist-toggle" data-id="<%= listing._id %>">
            <button class="wishlist-index" type="button" style="background: none; border: none; cursor: pointer;">
              <i 
                class="fa-heart <%= userWishlist.includes(listing._id.toString()) ? 'fa-solid' : 'fa-regular' %>" 
                style="color: <%= userWishlist.includes(listing._id.toString()) ? 'red' : 'white' %>;"
              ></i>
            </button>
          </div>
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="property-images swiper">
          
          <div class="swiper-wrapper">
          <% if (listing.images && listing.images.length > 0) { %>
            <% for (let i = 0; i < listing.images.length; i++) { %>
              <% if (listing.images[i] && listing.images[i].url) { %>
                <div class="swiper-slide">
                  <img
                    src="<%= listing.images[i].url.replace('/upload', '/upload/w_400') %>"
                    class="card-img-top" 
                    alt="listing_image" 
                    style="height: 18.5rem;"
                  />
                </div>
                <div class="card-img-overlay"></div>
              <% } %>
            <% } %>
          <% } else { %>
            <div class="swiper-slide">
              <img
                src="/images/default.jpeg"
                class="card-img-top"
                alt="default_image"
                style="height: 18.5rem;"
              />
            </div>
            <div class="card-img-overlay"></div>
          <% } %>
          </div>
          <div class="swiper-pagination"></div>
          <div class="swiper-button swiper-button-next">
            <i class="fa-solid fa-angle-right icon-a"></i>
          </div>
          <div class="swiper-button swiper-button-prev">
            <i class="fa-solid fa-angle-left icon-a"></i>
          </div> 
          </div> 
            
            <div class="card-body mt-3 mb-3">
              <p class="card-text">
               <b> <%= listing.title %></b> <br>
                <%= listing.location %>,<%= listing.country %> <br>
                &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
                <i class="tax-info">&nbsp; + 18% GST</i>
              </p>
            </div>
          
        </a>
        </div>
      <% } %> 
    </div>
  
  </body>
   
  <!-- wishlist toggler -->
  <script>
document.addEventListener('DOMContentLoaded', function() {
  // Handle wishlist toggle clicks
  document.addEventListener('click', async function(e) {
    // Check if click was on a wishlist button or icon
    const wishlistBtn = e.target.closest('.wishlist-toggle, .wishlist-index, .fa-heart');
    
    if (wishlistBtn) {
      e.preventDefault();
      const container = e.target.closest('.wishlist-toggle');
      const listingId = container.dataset.id;
      const icon = container.querySelector('.fa-heart');
      
      try {
        const response = await fetch(`/listings/${listingId}/wishlist-toggle`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          credentials: 'include'
        });

        const data = await response.json();

        if (data.success) {
          // Toggle icon appearance
          if (data.isWishlisted) {
            icon.classList.remove("fa-regular");
            icon.classList.add("fa-solid");
            icon.style.color = "red";
          } else {
            icon.classList.remove("fa-solid");
            icon.classList.add("fa-regular");
            icon.style.color = "white";
          }

          // Show flash message
          showFlashMessage(data.message, 'success');
        }
      } catch (error) {
        console.error('Error toggling wishlist:', error);
        showFlashMessage('Failed to update wishlist', 'error');
      }
    }
  });

  // Flash message function
  function showFlashMessage(message, type) {
    const flashBox = document.createElement("div");
    flashBox.innerText = message;
    flashBox.className = `flash-message ${type}`;
    document.body.appendChild(flashBox);
    setTimeout(() => flashBox.classList.add("show"), 10);
    setTimeout(() => {
      flashBox.classList.remove("show");
      setTimeout(() => flashBox.remove(), 500);
    }, 3000);
  }
});
</script>