<% layout("/layouts/boilerplate") %>

<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const listing = <%- JSON.stringify(listing) %>;
</script>

<% if (listing.images.length === 2) { %>
<style>
  .show-img{
    height: 53vh;
    width: 34rem !important;
    padding-right: 0.15rem;
    border-bottom-right-radius: 0 !important;
    border-top-right-radius: 0 !important;
  }
  .show-img1{
    height: 53vh;
    width: 34rem !important;
    padding-left: 0.15rem;
    border-bottom-left-radius: 0 !important;
    border-top-left-radius: 0 !important;
  }
</style>
<% } %>

<% if (listing.images.length === 3) { %>
<style>
  .image-collage-3 {
  display: flex;
  width: 100%;
  height: 53vh; 
  gap: 5px;
  overflow: hidden;
}

.left, .right {
  width: 50%;
  height: 100%;
  overflow: hidden;
}

.left {
  display: flex;
}

.left img {
  width: 100% !important;
  height: 100% !important;
  object-fit: cover;
  border-top-left-radius: 12px;
  border-bottom-left-radius: 12px;
  border-top-right-radius: 0 !important;
  border-bottom-right-radius: 0 !important;
}

.right {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.right img {
  width: 100% !important;
  height: 50% !important;
  object-fit: cover;
}

/* Corner radius for the right side (top-right and bottom-right only) */
.right img:nth-child(1) {
  width: 32rem !important;
  border-top-right-radius: 12px !important;
  border-top-left-radius: 0 !important;
  border-bottom-right-radius: 0 !important;
  border-bottom-left-radius: 0 !important;
}

.right img:nth-child(2) {
  width: 33rem !important;
  border-top-right-radius: 0 !important;
  border-top-left-radius: 0 !important;
  border-bottom-right-radius: 12px !important;
  border-bottom-left-radius: 0 !important;
}

</style>
<% } %>

<% if (listing.images.length === 4) { %>
<style>
  .image-collage-4 {
    display: flex;
    flex-wrap: wrap;
    width: 100%;
    height: 53vh;
    gap: 0.3rem;
  }

  .image-collage-4 img {
    width: calc(50% - 0.15rem);
    height: calc(50% - 0.15rem);
    object-fit: cover;
    border-radius: 0.5rem;
  }

  .image-collage-4 img:nth-child(1) {
    border-top-left-radius: 1rem;
    border-bottom-right-radius: 0;
    border-top-right-radius: 0;
  }

  .image-collage-4 img:nth-child(2) {
    border-top-right-radius: 1rem;
    border-bottom-left-radius: 0;
    border-top-left-radius: 0;
  }

  .image-collage-4 img:nth-child(3) {
    border-bottom-left-radius: 1rem;
    border-bottom-right-radius: 0;
    border-top-right-radius: 0;
  }

  .image-collage-4 img:nth-child(4) {
    border-bottom-right-radius: 1rem;
    border-bottom-left-radius: 0;
    border-top-left-radius: 0;
  }
</style>
<% } %>

<% if (listing.images.length === 5) { %>
<style>
.image-collage-5 {
  display: flex;
  width: 100%;
  height: 53vh; 
  gap: 5px;
  overflow: hidden;
}

.left, .right {
  width: 50%;
  height: 100%;
  overflow: hidden;
}

.left {
  display: flex;
}

.left img {
  width: 100% !important;
  height: 100% !important;
  object-fit: cover;
  border-top-left-radius: 12px;
  border-bottom-left-radius: 12px;
  border-top-right-radius: 0 !important;
  border-bottom-right-radius: 0 !important;
}

.right {
  display: grid;
  grid-template-columns: 1fr 1fr !important;
  grid-template-rows: 1fr 1fr !important;
  gap: 5px;
}

.right img {
  width: 100% !important;
  height: 100% !important;
  object-fit: cover;
}

/* Corner radius for the right side (top-right and bottom-right only) */
.right img:nth-child(1), .right img:nth-child(3) {
  border-radius: 0 !important;
  width: 14.9rem !important;
  height: 9.9rem !important;
}

.right img:nth-child(2) {
  width: 16.5rem !important;
  height: 9.9rem !important;
  border-top-right-radius: 12px !important;
  border-top-left-radius: 0 !important;
  border-bottom-right-radius: 0 !important;
  border-bottom-left-radius: 0 !important;
}

.right img:nth-child(4) {
  width: 16.5rem !important;
  height: 9.5rem !important;
  border-top-right-radius: 0 !important;
  border-top-left-radius: 0 !important;
  border-bottom-right-radius: 12px !important;
  border-bottom-left-radius: 0 !important;
}

</style>  
<% } %>


<div class="row mt-3">
  <div class="col-8 offset-4">
    <h3><b><%= listing.title %></b></h3>
  </div>
    <% if(currentUser && currentUser._id.equals(listing.owner._id)) { %>
    <div class="dropdown dot">
            <button 
              class="btn dropdown-toggle" 
              type="button" 
              id="dropdownMenuButton1" 
              data-bs-toggle="dropdown" 
              aria-expanded="false"
            >
            <div><img class="imge" src="/images/3dot.jpeg" /></div>
            </button>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item edit" href="/listings/<%= listing._id%>/edit">Edit</a></li>
              <li><a href="/listings/wishlist" style="text-decoration: none; color: black;">Wishlist</a></li>
              <li>
                <button class="dropdown-item text-danger" onclick="openModal('<%= listing._id %>')">Delete</button>
              </li>
            </ul>
    </div>
    <% } %>
  


  <div class="card col-10 offset-1 show-card listing-card">
    <% if (listing.images.length === 3) { %>
    <div class="image-collage-3">
      <div class="left">
        <img src="<%= listing.images[0].url %>" class="card-img-top show-img" alt="listing_image" />
      </div>
      <div class="right">
        <img src="<%= listing.images[1].url %>" class="card-img-top show-img1" alt="listing_image" />
        <img src="<%= listing.images[2].url %>" class="card-img-top show-img2" alt="listing_image" />
      </div>
    </div>
    <% } else if (listing.images.length === 4) { %>
    <div class="image-collage-4">
    <% for (let i = 0; i < 4; i++) { %>
      <img src="<%= listing.images[i].url %>" alt="listing_image" />
    <% } %>
    </div>
    <% } else if (listing.images.length === 5) { %>
    <div class="image-collage-5">
      <div class="left">
        <img src="<%= listing.images[0].url %>" class="card-img-top show-img" alt="listing_image" />
      </div>
      <div class="right">
        <img src="<%= listing.images[1].url %>" class="card-img-top show-img1" alt="listing_image" />
        <img src="<%= listing.images[2].url %>" class="card-img-top show-img2" alt="listing_image" />
        <img src="<%= listing.images[3].url %>" class="card-img-top show-img3" alt="listing_image" />
        <img src="<%= listing.images[4].url %>" class="card-img-top show-img4" alt="listing_image" />
      </div>
    </div>
    <% } else { %>
    <div class="d-flex">
    <% if (listing.images[0] && listing.images[0].url) { %>
    <img 
      src="<%= listing.images[0].url %>" 
      class="card-img-top show-img" 
      alt="listing_image"
    />
    <% } %>
    <% if (listing.images[1] && listing.images[1].url) { %>
    <img 
      src="<%= listing.images[1].url %>" 
      class="card-img-top show-img1" 
      alt="listing_image"
    />
    <% } %>
    <% if (listing.images[2] && listing.images[2].url) { %>
    <img 
      src="<%= listing.images[2].url %>" 
      class="card-img-top show-img2" 
      alt="listing_image"
    />
    <% } %>
    <% if (listing.images[3] && listing.images[3].url) { %>
    <img 
      src="<%= listing.images[3].url %>" 
      class="card-img-top show-img3" 
      alt="listing_image"
    />
    <% } %>
    <% if (listing.images[4] && listing.images[4].url) { %>
    <img 
      src="<%= listing.images[4].url %>" 
      class="card-img-top show-img4" 
      alt="listing_image"
    />
    <% } %>
    </div>
    <% } %>
    
    <div class="d-flex justify-content-between">
    <div class="card-body">
      <p class="card-text mt-2"><i>Owned by <%= listing.owner.username %></i></p>

      <p class="card-text"><%=listing.description%> </p>  
      <p class="card-text">
        &#8377; <%= listing.price.toLocaleString("en-IN") %>
      </p>
      <p class="card-text"><%=listing.location%></p>
      <p class="card-text"><%=listing.country%></p> 
    </div>
    <a href="/listings/<%= listing._id%>/Showimages" class="show-images">
      <i class="fa-solid fa-list-ul"></i>
      <p>Show all images</p>
    </a>

    <form id="wishlist-form" data-id="<%= listing._id %>">
      <button class="wishlist" type="submit" style="background: none; border: none; cursor: pointer;">
        <i 
          id="wishlist-icon"
          class="fa-heart <%= isWishlisted ? 'fa-solid' : 'fa-regular' %>" 
          style="color: <%= isWishlisted ? 'red' : 'black' %>;"
        ></i>
      </button>
    </form>
    </div>
    </div>
  
  <div class="col-10 offset-1 mt-1 mb-3">
    <% if(currentUser) { %>
    <hr>
    <h3><b>Leave a Review</b></h3>
    <form 
      action="/listings/<%= listing._id %>/reviews" 
      method="POST" 
      novalidate 
      class="needs-validation" 
    >
      <div>
        <label for="rating" class="form-label">Rating</label>
        <fieldset class="starability-slot">
          <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
          <input type="radio" id="first-rate1" name="review[rating]" value="1" />
          <label for="first-rate1" title="Terrible">1 star</label>
          <input type="radio" id="first-rate2" name="review[rating]" value="2" />
          <label for="first-rate2" title="Not good">2 stars</label>
          <input type="radio" id="first-rate3" name="review[rating]" value="3" />
          <label for="first-rate3" title="Average">3 stars</label>
          <input type="radio" id="first-rate4" name="review[rating]" value="4" />
          <label for="first-rate4" title="Very good">4 stars</label>
          <input type="radio" id="first-rate5" name="review[rating]" value="5" />
          <label for="first-rate5" title="Amazing">5 stars</label>
        </fieldset>
        <div class="invalid-feedback">
          Please provide a rating.
        </div>
      </div>

      <div class="mb-3">
        <label for="comment" class="form-label">Comment</label>
        <textarea 
          id="comment" 
          name="review[comment]" 
          rows="5" 
          cols="30"
          class="form-control"
          placeholder="Write your review here..."
          required
        ></textarea>
        <div class="invalid-feedback">
          Please provide a comment.
        </div>
      </div>

      <button class="btn btn-dark edit-btn">Submit</button>

    </form>
    <% } %>
     
    <% if(listing.reviews.length > 0) { %>
      <hr>
    <p><b>All Reviews</b></p>
    <div class="row">
      <% for(review of listing.reviews) { %>
        <div class="card col-5 flex ms-3 mb-3 offset-6">
          <div class="card-body ms-3 ">
            <h5 class="card-title">@<%= review.author.username %></h5>
            <p class="starability-result card-text" data-rating= "<%= review.rating %>" > </p>
            <p class="card-text"><%= review.comment %></p>
            
              <small class="text-muted">
                <%= review.updatedAt ? review.updatedAt.toLocaleString("en-IN") : review.createdAt.toLocaleString("en-IN") %>
                <% if (review.updatedAt && review.updatedAt.getTime() !== review.createdAt.getTime()) { %>
                  (Edited)
                <% } else { %>
                  (Posted)
                <% } %>
              </small>
            </p>

            <% if(currentUser && currentUser._id.equals(review.author._id)) { %>

              <div class="btns mb-3 ">
                <a 
                  href="/listings/<%= listing._id %>/reviews/<%= review._id %>/edit" 
                  class="btn btn-dark edit-btn"
                  style="width: 4rem;"
                >Edit</a>
                
                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                  <button class="btn btn-dark offset-2">Delete</button>
                </form>
              </div>              
              
            <% } %>
          </div>
        </div>
      <% } %>
    </div>
    <% } %>
  </div>
  <div class="col-10 offset-1 mb-2">
    <hr>
    <h3><b>Where you'll be</b></h3>
    <div id="map" class="mt-4 mb-5"></div>
  </div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="modal">
  <div class="modal-content">
    <p>Are you sure you want to delete this listing?</p>
    <form id="deleteForm" method="POST">
      <button type="submit" class="btn btn-danger">Yes, Delete</button>
      <button type="button" onclick="closeModal()" class="btn btn-secondary">Cancel</button>
    </form>
  </div>
</div>

<script>
  function openModal(listingId) {
    const modal = document.getElementById('deleteModal');
    const form = document.getElementById('deleteForm');
    form.action = `/listings/${listingId}?_method=DELETE`;
    modal.style.display = 'block';
  }

  function closeModal() {
    document.getElementById('deleteModal').style.display = 'none';
  }

  // Optional: close modal on outside click
  window.onclick = function(event) {
    const modal = document.getElementById('deleteModal');
    if (event.target == modal) {
      modal.style.display = "none";
    }
  }
</script>



<script src="/js/map.js"></script>  

<!-- wishlist-toggler -->
<script>
  document.getElementById('wishlist-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const listingId = e.currentTarget.dataset.id;
    const icon = document.getElementById('wishlist-icon');

    try {
      const response = await fetch(`/listings/${listingId}/wishlist-toggle`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        credentials: 'include'
      });

      const data = await response.json();

      if (data.success) {
        if (data.isWishlisted) {
          icon.classList.remove("fa-regular");
          icon.classList.add("fa-solid");
          icon.style.color = "red";
        } else {
          icon.classList.remove("fa-solid");
          icon.classList.add("fa-regular");
          icon.style.color = "black";
        }

        // Flash message like e-commerce
        const flashBox = document.createElement("div");
        flashBox.innerText = data.isWishlisted ? "Added to wishlist!" : "Removed from wishlist!";
        flashBox.className = "flash-message success";
        document.body.appendChild(flashBox);
        setTimeout(() => flashBox.classList.add("show"), 10);
        setTimeout(() => {
          flashBox.classList.remove("show");
          setTimeout(() => flashBox.remove(), 500);
        }, 3000);
      }
    } catch (error) {
      console.error('Error toggling wishlist:', error);
    }
  });
</script>
