<% layout("/layouts/boilerplate") %>

<div class="row">
    <div class="col-8 offset-2">
        <br> <br>
        <h3 class="mt-3 col-6 offset-4 font-weight-normal">Edit The review</h3>
        <form 
          method="POST" 
          action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=PUT"
          novalidate
          class="needs-validation"
        >
            <div class="mb-3 mt-3">
                <label for="rating" class="form-label"></label>
                <fieldset class="starability-slot">
                  <legend><b>Rating:</b></legend>
                  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0"
                    <%= review.rating === 0 ? "checked" : "" %> aria-label="No rating." />

                  <input type="radio" id="first-rate1" name="review[rating]" value="1"
                    <%= review.rating === 1 ? "checked" : "" %> />
                  <label for="first-rate1" title="Terrible">1 star</label>

                  <input type="radio" id="first-rate2" name="review[rating]" value="2"
                    <%= review.rating === 2 ? "checked" : "" %> />
                  <label for="first-rate2" title="Not good">2 stars</label>

                  <input type="radio" id="first-rate3" name="review[rating]" value="3"
                    <%= review.rating === 3 ? "checked" : "" %> />
                  <label for="first-rate3" title="Average">3 stars</label>

                  <input type="radio" id="first-rate4" name="review[rating]" value="4"
                    <%= review.rating === 4 ? "checked" : "" %> />
                  <label for="first-rate4" title="Very good">4 stars</label>

                  <input type="radio" id="first-rate5" name="review[rating]" value="5"
                    <%= review.rating === 5 ? "checked" : "" %> />
                  <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
                <div class="valid-feedback">Great job! Rating has been updated successfully.</div>
                <div class="invalid-feedback">Please add a rating!</div>
            </div>
            <div class="mb-3 mt-3">
                <label for="comment" class="form-label"><b>@<%= review.author.username %></b></label>
                <textarea
                  name="review[comment]" 
                  id="comment"
                  class="form-control"
                  rows="5"
                  required
                ><%= review.comment %>
                </textarea> 
                <div class="valid-feedback">Awesome! Review has been updated successfully.</div>
                <div class="invalid-feedback">Please add a Review!</div>
            </div>
    
            <button class="btn btn-dark edit-btn offset-5 mt-2">Edit</button>
            <br> <br> <br> <br>
        </form>
    </div>
</div>

                
